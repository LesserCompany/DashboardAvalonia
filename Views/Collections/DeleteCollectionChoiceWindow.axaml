<Window x:Name="DeleteChoiceWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LesserDashboardClient.ViewModels.Collections"
        xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia.ProgressRing"
        x:DataType="vm:DeleteCollectionChoiceViewModel"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="420"
        x:Class="LesserDashboardClient.Views.Collections.DeleteCollectionChoiceWindow"
        Title="{Tr 'Delete collection'}"
        Width="480"
        MinHeight="320"
        Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Grid RowDefinitions="Auto,*" Margin="20">
    <!-- Painel de escolha: Exclusão total | Exclusão parcial -->
    <StackPanel Grid.Row="0" IsVisible="{Binding ShowChoicePanel}" Spacing="16">
      <TextBlock Text="{Tr 'How do you want to delete this collection?'}"
                 FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding CollectionDisplayName}" 
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 FontSize="12" TextTrimming="CharacterEllipsis"/>
      <StackPanel Orientation="Vertical" Spacing="10" Margin="0,12,0,0">
        <Button Command="{Binding ChooseFullDeletionCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="16,12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock Text="{Tr 'Full deletion'}" VerticalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
        <TextBlock Text="{Tr 'Request deletion of the entire collection. You can cancel later from the deleted collections list.'}"
                   FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextWrapping="Wrap" Margin="0,-4,0,0"/>
        <Button Command="{Binding ChoosePartialDeletionCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="16,12"
                Margin="0,8,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81E;" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock Text="{Tr 'Partial deletion'}" VerticalAlignment="Center" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
        <TextBlock Text="{Tr 'List graduates and remove only the photos of selected graduates from the collection.'}"
                   FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextWrapping="Wrap" Margin="0,-4,0,0"/>
      </StackPanel>
    </StackPanel>

    <!-- Painel de exclusão parcial: lista de formandos + lixeira -->
    <Grid Grid.Row="0" IsVisible="{Binding ShowPartialPanel}" RowDefinitions="Auto,Auto,*,Auto">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
        <Button Command="{Binding BackToChoiceCommand}" Padding="8,4">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72B;" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock Text="{Tr 'Back'}" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <TextBlock Text="{Tr 'Partial deletion'}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </StackPanel>
      <TextBlock Grid.Row="1" 
                 Text="{Tr 'Click the trash icon next to a graduate to remove only that graduates photos from the collection.'}"
                 FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <Border Grid.Row="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,12">
        <Grid RowDefinitions="Auto,*">
          <ui:ProgressRing Grid.Row="0" IsVisible="{Binding GraduatesLoading}" IsIndeterminate="True" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,8"/>
          <ScrollViewer Grid.Row="1" IsVisible="{Binding !GraduatesLoading}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="4">
              <TextBlock IsVisible="{Binding LoadGraduatesError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         Text="{Binding LoadGraduatesError}"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                         TextWrapping="Wrap"/>
              <ItemsControl ItemsSource="{Binding GraduatesList}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8"
                            Margin="0,2">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding CPF}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                IsEnabled="False"
                                ToolTip.Tip="Remover fotos deste formando da coleção (em breve)"
                                Padding="8,4"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                Opacity="0.6">
                          <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
      <Button Grid.Row="3" Command="{Binding CloseWindowCommand}" HorizontalAlignment="Right">
        <TextBlock Text="{Tr 'Close'}"/>
      </Button>
    </Grid>
  </Grid>
</Window>

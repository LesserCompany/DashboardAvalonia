<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:LesserDashboardClient.Views.Shared"
             xmlns:vm="clr-namespace:LesserDashboardClient.ViewModels.SearchGraduate"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:SearchGraduateViewModel"
             x:Class="LesserDashboardClient.Views.SearchGraduate.SearchGraduateControl"
             x:Name="root">
  <UserControl.DataContext>
    <vm:SearchGraduateViewModel />
  </UserControl.DataContext>
  <Grid RowDefinitions="Auto,*,Auto">
    <ListBox x:Name="PART_SectionTabs"
             Grid.Row="0"
             SelectedIndex="{Binding SelectedSectionIndex}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0,0,0,4">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="4" />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="10,8" />
          <Setter Property="Margin" Value="0,0,4,0" />
          <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="ListBoxItem:selected">
          <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
          <Setter Property="Foreground" Value="White" />
        </Style>
      </ListBox.Styles>
      <ListBoxItem ToolTip.Tip="{Tr 'SG tab CPF by collection tooltip'}">
        <TextBlock Text="{Tr 'SG tab CPF by collection'}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" />
      </ListBoxItem>
      <ListBoxItem ToolTip.Tip="{Tr 'SG tab CPF for collection tooltip'}">
        <TextBlock Text="{Tr 'SG tab CPF for collection'}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" />
      </ListBoxItem>
      <ListBoxItem ToolTip.Tip="{Tr 'SG tab review photos chosen tooltip'}">
        <TextBlock Text="{Tr 'SG tab review photos chosen'}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" />
      </ListBoxItem>
      <ListBoxItem ToolTip.Tip="{Tr 'SG tab manual treatment photos tooltip'}">
        <TextBlock Text="{Tr 'SG tab manual treatment photos'}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" />
      </ListBoxItem>
    </ListBox>

    <WebView x:Name="PART_WebView"
             Grid.Row="1"
             MinWidth="100"
             MinHeight="100"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             Margin="0"
             Padding="0"
             Url="{Binding ActiveUrl, FallbackValue=about:blank, TargetNullValue=about:blank}" />

    <Border Grid.Row="2"
            Background="Transparent"
            Padding="0">
      <shared:OpenInWebButton x:Name="OpenInWebButtonControl"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,6,0,6" />
    </Border>
  </Grid>
</UserControl>
